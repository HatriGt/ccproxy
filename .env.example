# Copy to .env and adjust per machine.
# cp .env.example .env

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=ccproxy
CLIPROXY_IMAGE_TAG=v7.1.63
CLIPROXY_API_IMAGE=ccproxy-cli-proxy-api:local
CURSOR_SHIM_IMAGE=ccproxy-cursor-shim:local

# --- Public URL (Cursor OpenAI override) ---
PUBLIC_HOSTNAME=cliproxy.yourdomain.com
PUBLIC_URL=https://cliproxy.yourdomain.com
CURSOR_BASE_URL=https://cliproxy.yourdomain.com/v1

# --- API auth (Cursor sends this as OpenAI API key) ---
CLIPROXY_API_KEY=dummy

# --- Logging / telemetry (rendered into config.yaml at container start) ---
# request-log + logging-to-file write per-request logs that grow fast on disk,
# so they default OFF. Flip to true only when debugging, then back to false.
# usage-statistics stays on so token usage can still be tracked.
CCPROXY_DEBUG=false
CCPROXY_LOGGING_TO_FILE=false
CCPROXY_REQUEST_LOG=false
CCPROXY_USAGE_STATS=true

# --- Usage tracking (per-user day-wise token stats) ---
# The usage-tracker sidecar drains /v0/management/usage-queue into SQLite.
# Requires remote-management enabled (internal-only; 8318 is never published).
# CCPROXY_MGMT_SECRET_KEY defaults to CLIPROXY_MGMT_KEY if left blank.
CCPROXY_ALLOW_REMOTE_MGMT=true
CCPROXY_MGMT_SECRET_KEY=
USAGE_TRACKER_IMAGE=ccproxy-usage-tracker:local
USAGE_POLL_SECS=15
USAGE_BATCH=200

# --- Management API ---
CLIPROXY_MGMT_KEY=change-me-plain-mgmt-key
CLIPROXY_REMOTE_MGMT_SECRET_KEY=change-me-bcrypt-or-plain-secret

# --- Service ports ---
CLIPROXY_PORT=8318
CURSOR_SHIM_PORT=8320
CURSOR_SHIM_HOST=0.0.0.0
CLIPROXY_UPSTREAM=http://cli-proxy-api:8318

# --- Mac local shim ---
CLIPROXY_UPSTREAM_LOCAL=http://127.0.0.1:8318
CURSOR_SHIM_HOST_LOCAL=127.0.0.1

# --- Tunnel: vps | quick | named | docker ---
CLIPROXY_TUNNEL_MODE=vps
CLIPROXY_TUNNEL_HOSTNAME=cliproxy.yourdomain.com
CLIPROXY_TUNNEL_URL=https://cliproxy.yourdomain.com
CLIPROXY_TUNNEL_URL_FILE=$HOME/.config/cliproxyapi/cursor-tunnel-url
CLIPROXY_DNS=8.8.8.8
CLIPROXY_TUNNEL_URL_WAIT_SECS=45

# --- Cloudflare named tunnel (optional) ---
CLIPROXY_NAMED_TUNNEL_NAME=cursor-cliproxy
CLIPROXY_NAMED_TUNNEL_ID=
CLIPROXY_NAMED_TUNNEL_CONFIG=$HOME/.config/cliproxyapi/cloudflared.yml
CLIPROXY_NAMED_TUNNEL_CREDENTIALS=$HOME/.cloudflared/TUNNEL_ID.json
CLIPROXY_DNS_MODE=spaceship

# --- VPS / Dokploy ---
VPS_SSH_HOST=your-vps
CLIPROXY_VPS_SSH_HOST=your-vps
VPS_PUBLIC_IP=203.0.113.10
VPS_DEPLOY_DIR=/opt/ccproxy
CLIPROXY_VPS_BRIDGE_PORT=18320
CLIPROXY_VPS_TUNNEL_PORT=18321
CLIPROXY_VPS_TRAEFIK_FILE=cliproxy-cursor.yml

# --- Health checks ---
CLIPROXY_TEST_MODEL=ak-claude-sonnet-4.6
CLIPROXY_TEST_RETRIES=20
CLIPROXY_TEST_RETRY_SECS=3
CURSOR_CLAUDE_WAIT_SECS=45

# --- Mac CLIProxy / VibeProxy ---
CLIPROXY_CONFIG=$HOME/.cli-proxy-api/merged-config.yaml
CLIPROXY_CONFIG_FALLBACK=$HOME/.config/cliproxyapi/config.yaml
CLIPROXY_BIN=$HOME/.local/bin/cli-proxy-api
CLIPROXY_AUTH_DIR=$HOME/.cli-proxy-api
LOCAL_BIN=$HOME/.local/bin

# --- Logs (Mac) ---
CLIPROXY_TUNNEL_LOG=$HOME/Library/Logs/cliproxyapi-tunnel.log
CLIPROXY_VPS_RELAY_LOG=$HOME/Library/Logs/cliproxy-vps-relay.log
CLIPROXY_VPS_RELAY_PID=$HOME/.config/cliproxyapi/vps-relay.pid
